NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin server-side settings for DocuSign Firestore writes.
# Use exactly one approach below.
FIREBASE_ADMIN_SERVICE_ACCOUNT_PATH=keys/firebase-admin-service-account.json
# FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
# FIREBASE_ADMIN_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
# FIREBASE_ADMIN_PROJECT_ID=your-project-id
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-admin-service-account.json

# DocuSign server-side settings
# Use demo for sandbox and production for live.
DOCUSIGN_ENVIRONMENT=demo

# Required
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_USER_ID=your-impersonated-user-guid
DOCUSIGN_CONSENT_REDIRECT_URI=http://localhost:3000/ds/callback
DOCUSIGN_SIGNING_RETURN_URL=http://localhost:3000/signing-complete

# Optional but recommended if the impersonated user has access to multiple accounts.
DOCUSIGN_ACCOUNT_ID=your-account-id

# Optional override if you need a non-default auth server.
# DOCUSIGN_AUTH_SERVER=account-d.docusign.com

# Private key options: use exactly one of these.
DOCUSIGN_PRIVATE_KEY_PATH=keys/docusign-private.key
# DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# DOCUSIGN_PRIVATE_KEY_BASE64=base64-encoded-private-key

# Optional iframe/origin helpers.
DOCUSIGN_ALLOWED_ORIGINS=http://localhost:3000

# Optional defaults for the embedded-signing demo page.
DOCUSIGN_TEST_SIGNER_NAME=
DOCUSIGN_TEST_SIGNER_EMAIL=

# Your RSA public key does not need to live in the app.
# Keep it registered with DocuSign in Apps and Keys.
